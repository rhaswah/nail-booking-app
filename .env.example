# ─────────────────────────────────────────────────────────────
# byChronos connection. All values are SERVER-ONLY (read in API routes /
# server components, never shipped to the browser). Never prefix with
# NEXT_PUBLIC_. Copy this file to `.env.local` (gitignored) and edit there.
# ─────────────────────────────────────────────────────────────

# Which data source the app uses:
#   bychronos-public (DEFAULT) — the salon's REAL live catalog, techs, and
#       availability via the public byChronos booking API. No credentials needed
#       for reads. This is what the customer booking page uses.
#   mock — built-in sample data, no network. Good for offline UI work.
#   bychronos — merchant Go3 Schedule API (OAuth). Only if you need the full
#       merchant API; requires the BYCHRONOS_* OAuth block far below.
BOOKING_PROVIDER=bychronos-public

# ── Public booking API (used by bychronos-public) ─────────────────────────
# The salon's public location slug — the last path segment of its booking URL:
#   https://go.bychronos.com/l/<THIS>/a/services
BYCHRONOS_LOCATION_URL=chicago-60657-fairy-nail-spa-805539
# Origin of the byChronos booking site (rarely needs changing).
BYCHRONOS_SITE_ORIGIN=https://go.bychronos.com

# Writes are OFF by default so testing never creates real appointments in the
# live salon. Set to `true` only when you intend bookings to hit byChronos for real.
BYCHRONOS_ALLOW_WRITE=false

# ── Merchant OAuth API (only used when BOOKING_PROVIDER=bychronos) ─────────
# Ask byChronos/Go3 (developer@go3technology.com) for a dedicated API client.
BYCHRONOS_BASE_URL=https://schedule.go3apis.com
BYCHRONOS_APPLICATION_ID=
BYCHRONOS_LOCATION_ID=
BYCHRONOS_CLIENT_ID=
BYCHRONOS_CLIENT_SECRET=
BYCHRONOS_USERNAME=
BYCHRONOS_PASSWORD=
