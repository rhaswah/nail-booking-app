# ─────────────────────────────────────────────────────────────
# byChronos (Go3 Schedule API) connection.
# These are SERVER-ONLY secrets. They are read in Next.js API routes,
# never shipped to the browser. Do NOT prefix any of these with NEXT_PUBLIC_.
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# ─────────────────────────────────────────────────────────────

# Which provider the app uses: `mock` = built-in sample data (default, no creds
# needed). `bychronos` = live byChronos POS.
BOOKING_PROVIDER=mock

# API host. Use the UAT host to test against a sandbox first, then flip to prod.
#   Production: https://schedule.go3apis.com
#   UAT/sandbox: https://schedule-uat.go3apis.com
BYCHRONOS_BASE_URL=https://schedule.go3apis.com

# Identifies your salon location. Sent as X-APPLICATION-ID / X-LOCATION-ID headers.
BYCHRONOS_APPLICATION_ID=
BYCHRONOS_LOCATION_ID=

# OAuth2 client (Laravel Passport). Ask byChronos/Go3 for a dedicated API client
# rather than reusing a human login — it's scoped and revocable.
BYCHRONOS_CLIENT_ID=
BYCHRONOS_CLIENT_SECRET=

# Merchant account used to create bookings (the OAuth password grant).
# Prefer a dedicated "API/booking" staff user over your personal owner login,
# so rotating your own password never breaks the site.
BYCHRONOS_USERNAME=
BYCHRONOS_PASSWORD=
